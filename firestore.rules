rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hardened Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Validation Helpers
    function isValidJobPost(data) {
      return data.title is string && data.title.size() <= 200 
          && data.description is string && data.description.size() <= 5000
          && data.budget is number && data.budget >= 0
          && data.type in ['scripting', 'building']
          && data.status in ['open', 'in-progress', 'closed']
          && data.authorId is string;
    }

    match /{document=**} {
      allow read, write: if false; 
    }

    match /jobPosts {
      allow list: if true;
      match /{postId} {
        allow read, write: if true;
      }
    }

    match /applications {
      allow list: if true;
      match /{appId} {
        allow read, write: if true;
      }
    }

    match /chats {
      match /{chatId} {
        allow get, list: if isSignedIn() && request.auth.uid in resource.data.participants;
        allow create: if isSignedIn() && request.auth.uid in incoming().participants;
        allow update: if isSignedIn() && request.auth.uid in resource.data.participants && request.auth.uid in incoming().participants;
        
        match /messages/{messageId} {
          allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
      }
    }
  }
}
