rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hardened Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Validation Helpers
    function isValidJobPost(data) {
      return data.title is string && data.title.size() <= 200 
          && data.description is string && data.description.size() <= 5000
          && data.budget is number && data.budget >= 0
          && data.type in ['scripting', 'building']
          && data.status in ['open', 'in-progress', 'closed']
          && data.authorId is string;
    }

    match /{document=**} {
      allow read, write: if false; 
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /jobPosts/{postId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(postId);
      allow create: if isSignedIn() && isValidId(postId) && isValidJobPost(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(postId) && isValidJobPost(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && isAdmin())
      );
    }
  }
}
